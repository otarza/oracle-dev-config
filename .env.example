# Copy this file to .env and fill in your values
# .env is gitignored — never commit real passwords

# Password for Oracle built-in accounts: SYS, SYSTEM, PDBADMIN
# Rules: 8-30 chars, at least 1 uppercase, 1 lowercase, 1 digit
ORACLE_PWD=YourStr0ngPassword!

# Separate password for the ORDS schema user
ORDS_PWD=YourOrdsP4ssword!
